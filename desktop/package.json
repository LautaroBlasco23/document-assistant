{
  "name": "document-assistant-desktop",
  "version": "1.0.0",
  "description": "Document Assistant Desktop App",
  "main": "build/main/main.js",
  "author": "Document Assistant <support@documentassistant.app>",
  "type": "module",
  "scripts": {
    "dev": "npm run build:preload && concurrently \"cd ../frontend && npm run dev\" \"wait-on tcp:5173 tcp:5174 && electron .\"",
    "build": "npm run build:main && npm run build:preload",
    "build:main": "vite build --config vite.main.config.ts",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:renderer": "cd ../frontend && npm run build",
    "dist": "npm run build:renderer && npm run build && electron-builder",
    "dist:linux": "npm run build:renderer && npm run build && electron-builder --linux",
    "dist:mac": "npm run build:renderer && npm run build && electron-builder --mac",
    "dist:win": "npm run build:renderer && npm run build && electron-builder --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "electron-log": "^5.0.0"
  },
  "build": {
    "appId": "com.documentassistant.app",
    "productName": "Document Assistant",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "build/**/*",
      "../frontend/dist/**/*"
    ],
    "extraResources": [],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Office"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
