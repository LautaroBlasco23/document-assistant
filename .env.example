# ── Nginx ──────────────────────────────────────────────────────────────────────
NGINX_PORT=80
DOMAIN=localhost
FORWARDED_PROTO=http

# Comma-separated origins the backend will accept (auto-computed by scripts/setupEnv.sh)
ALLOWED_ORIGINS=http://localhost

# ── Secrets (auto-generated by scripts/setupEnv.sh — do not commit .env) ──────
POSTGRES_PASSWORD=
NEO4J_PASSWORD=

# ── LLM provider ───────────────────────────────────────────────────────────────
# "groq" | "ollama" | "openrouter" | "huggingface"
DOCASSIST_LLM_PROVIDER=ollama

# Groq API key — required when DOCASSIST_LLM_PROVIDER=groq
# Get yours at https://console.groq.com
DOCASSIST_GROQ__API_KEY=

# OpenRouter API key — required when DOCASSIST_LLM_PROVIDER=openrouter
# Free key at https://openrouter.ai/keys
DOCASSIST_OPENROUTER__API_KEY=

# HuggingFace token — required when DOCASSIST_LLM_PROVIDER=huggingface
# Free token at https://huggingface.co/settings/tokens (Read role)
DOCASSIST_HUGGINGFACE__API_KEY=

# Optional: override the default model per provider
# DOCASSIST_OPENROUTER__MODEL=meta-llama/llama-3.1-8b-instruct:free
# DOCASSIST_HUGGINGFACE__MODEL=mistralai/Mistral-7B-Instruct-v0.3
