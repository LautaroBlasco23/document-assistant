{
  "name": "document-assistant",
  "version": "0.1.0",
  "description": "Local document reader with hybrid retrieval",
  "main": "./out/main/index.js",
  "author": "Document Assistant",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-builder --publish never",
    "dist": "electron-builder",
    "dist:win": "cross-env DOCASSIST_EXTERNAL_BACKEND=1 WINEARCH=win32 WINEPREFIX=/home/lautaroblasco23/.wine32 CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^25.0.0",
    "cross-env": "^7.0.3",
    "electron-vite": "^2.0.0",
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "typescript": "^5.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "@tanstack/react-query": "^5.0.0",
    "zustand": "^4.0.0",
    "axios": "^1.6.0",
    "@microsoft/fetch-event-source": "^2.0.0",
    "react-markdown": "^9.0.0",
    "tailwindcss": "^3.0.0",
    "autoprefixer": "^10.0.0",
    "postcss": "^8.0.0"
  },
  "build": {
    "appId": "com.document-assistant.app",
    "productName": "Document Assistant",
    "files": [
      "out"
    ],
    "directories": {
      "buildResources": "resources"
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "createDesktopShortcut": true
    }
  }
}
